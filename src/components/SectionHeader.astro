---
interface Props {
	label: string;
	linkText?: string;
	linkHref?: string;
	dot?: boolean;
}

const { label, linkText = 'View all', linkHref = '#', dot = true } = Astro.props;
---

<div class="section-header">
	<div class="label-group">
		{dot && <span class="dot" aria-hidden="true"></span>}
		<span class="label">{label}</span>
	</div>
	{
		linkText && (
			<a href={linkHref} class="view-link">
				{linkText} <span class="arrow">&rarr;</span>
			</a>
		)
	}
</div>

<style>
	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 0 0 20px;
	}
	.label-group {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-red);
		flex-shrink: 0;
	}
	.label {
		font-family: var(--font-body);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-black);
	}
	.view-link {
		font-family: var(--font-body);
		font-size: 13px;
		color: var(--color-black);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.arrow {
		transition: transform 150ms ease;
	}
	.view-link:hover .arrow {
		transform: translateX(2px);
	}
</style>
