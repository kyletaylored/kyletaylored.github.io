---
import { MobileNav } from './MobileNav';
import site from '../data/site.json';

const navLinks = [
	{ label: 'Projects', href: '/projects' },
	{ label: 'Articles', href: '/articles' },
	{ label: 'Lab', href: '/lab' },
	{ label: 'About', href: '/about' },
	{ label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 flex h-14 items-center justify-between bg-ink px-6 md:px-12">
	<a href="/" class="flex items-center gap-2.5">
		<div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-sm bg-teal">
			<span class="text-sm leading-none font-bold text-ink">K</span>
		</div>
		<span class="hidden text-sm font-semibold tracking-widest text-bg uppercase sm:inline">
			{site.brandLabel}
		</span>
	</a>

	<nav class="hidden items-center gap-8 md:flex">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					class="text-sm font-medium tracking-wide text-bg uppercase transition-colors hover:text-teal"
				>
					{link.label}
				</a>
			))
		}
		<button
			type="button"
			class="font-mono text-xs text-muted transition-colors hover:text-teal"
			aria-label="Open command palette"
			onclick="window.dispatchEvent(new CustomEvent('open-command-palette'))"
		>
			&#8984;K
		</button>
	</nav>

	<div class="md:hidden">
		<MobileNav links={navLinks} client:media="(max-width: 767px)" />
	</div>
</header>
