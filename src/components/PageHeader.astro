---
import Circle from './decor/Circle.astro';
import Triangle from './decor/Triangle.astro';

interface Props {
	title: string;
	description?: string;
	eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="relative overflow-hidden bg-ink px-6 py-12 md:px-12 md:py-16">
	<div class="pointer-events-none absolute -top-6 right-16 hidden opacity-[0.12] md:block">
		<Circle color="var(--color-teal)" size="120px" />
	</div>
	<div class="pointer-events-none absolute right-32 top-8 hidden opacity-15 md:block">
		<Triangle color="var(--color-yellow)" size="50px" />
	</div>

	<div class="relative mx-auto max-w-6xl">
		{eyebrow && <div class="mb-4 text-xs font-semibold tracking-widest text-teal uppercase">{eyebrow}</div>}
		<h1 class="mb-3 text-4xl font-bold tracking-tight text-bg md:text-5xl">{title}</h1>
		{description && <p class="max-w-xl text-base leading-relaxed text-muted-light">{description}</p>}
	</div>
</header>
<div class="h-1 bg-pink"></div>
