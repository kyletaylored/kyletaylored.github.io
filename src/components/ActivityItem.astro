---
interface Props {
	type?: 'experiment' | 'git' | 'tool' | 'update' | 'article' | 'commit';
	title: string;
	description: string;
	time: string;
	url?: string;
}

const typeConfig = {
	experiment: { label: 'New Experiment', color: 'var(--color-red)', icon: '⬡' },
	git: { label: 'Git Push', color: 'var(--color-yellow)', icon: '↑' },
	tool: { label: 'New Tool', color: 'var(--color-teal)', icon: '⬛' },
	update: { label: 'Experiment Updated', color: 'var(--color-pink)', icon: '↻' },
	article: { label: 'Published Article', color: 'var(--color-blue)', icon: '✦' },
	commit: { label: 'New Commit', color: 'var(--color-muted)', icon: '●' },
};

const { type = 'commit', description, time, url } = Astro.props;
const cfg = typeConfig[type] ?? typeConfig.commit;
const Tag = url ? 'a' : 'div';
---

<Tag class="activity-item" href={url} target={url ? '_blank' : undefined} rel={url ? 'noopener noreferrer' : undefined}>
	<div class="icon" style={{ color: cfg.color }}>{cfg.icon}</div>
	<div class="body">
		<div class="type" style={{ color: cfg.color }}>{cfg.label}</div>
		<div class="description">{description}</div>
	</div>
	<div class="time">{time}</div>
</Tag>

<style>
	.activity-item {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		padding: 10px 0;
		border-bottom: 1px solid var(--color-surface);
		text-decoration: none;
		color: inherit;
	}
	.icon {
		width: 28px;
		height: 28px;
		background: var(--color-surface);
		border-radius: var(--radius-md);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		font-size: 12px;
	}
	.body {
		flex: 1;
		min-width: 0;
	}
	.type {
		font-family: var(--font-body);
		font-size: 12px;
		font-weight: 600;
		margin-bottom: 2px;
	}
	.description {
		font-family: var(--font-body);
		font-size: 13px;
		color: var(--color-black);
		line-height: 1.4;
	}
	.time {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted-light, var(--color-muted));
		white-space: nowrap;
		flex-shrink: 0;
		padding-top: 2px;
	}
</style>
