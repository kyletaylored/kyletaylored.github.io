---
import Circle from './decor/Circle.astro';
import Triangle from './decor/Triangle.astro';
import HazardStripe from './decor/HazardStripe.astro';
import SocialIcon from './icons/SocialIcon.astro';
import site from '../data/site.json';

const currentYear = new Date().getFullYear();

const footerNavLinks = [
	{ label: 'Projects', href: '/projects' },
	{ label: 'Articles', href: '/articles' },
	{ label: 'Lab', href: '/lab' },
	{ label: 'About', href: '/about' },
	{ label: 'Contact', href: '/contact' },
];
---

<footer class="relative overflow-hidden bg-ink px-6 py-8 md:px-12 md:py-12">
	<div class="pointer-events-none absolute -bottom-5 right-[120px] opacity-90 md:right-[200px]">
		<Circle color="var(--color-pink)" size="80px" />
	</div>
	<div class="pointer-events-none absolute -top-8 right-[180px] hidden opacity-80 md:right-[280px] md:block">
		<Circle color="var(--color-teal)" size="60px" />
	</div>
	<div class="pointer-events-none absolute right-[100px] top-5 hidden opacity-90 md:right-[160px] md:block">
		<Triangle color="var(--color-yellow)" size="70px" />
	</div>
	<div class="absolute inset-x-0 bottom-0">
		<HazardStripe height="6px" />
	</div>

	<div class="relative mx-auto grid max-w-6xl gap-8 text-center md:grid-cols-3 md:items-start md:gap-6 md:text-left">
		<div>
			<p class="m-0 text-base leading-snug font-bold text-bg md:text-lg">{site.footerTaglineLine1}</p>
			<p class="m-0 text-base leading-snug font-bold text-bg md:text-lg">
				{site.footerTaglineLine2Prefix} <span class="text-teal">{site.footerTaglineLine2Accent}</span>
			</p>
		</div>
		<div class="flex flex-col items-center gap-2 md:items-center md:text-center">
			<div class="text-sm font-semibold text-bg">Built by Kyle Taylor</div>
			<div class="text-xs text-muted">&copy; {currentYear} Kyle Taylor</div>
		</div>
		<div class="flex flex-col items-center gap-4 md:items-end">
			<nav class="flex flex-wrap justify-center gap-x-4 gap-y-1.5 md:justify-end">
				{
					footerNavLinks.map((link) => (
						<a href={link.href} class="text-xs text-muted transition-colors hover:text-teal">
							{link.label}
						</a>
					))
				}
			</nav>
			<div class="flex gap-4">
				{
					site.socialLinks.map((link) => (
						<a
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
							class="text-bg transition-colors hover:text-teal"
						>
							<SocialIcon platform={link.platform} />
						</a>
					))
				}
			</div>
		</div>
	</div>
</footer>
