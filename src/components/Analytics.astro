---
/**
 * Google Tag Manager + Datadog RUM, wired from repo secrets at build time
 * (see .github/workflows/deploy.yml) rather than through Pages CMS content
 * — these are deployment/infra config, not editable site content. Each
 * block no-ops (renders nothing) when its env vars aren't set, so local
 * dev and PR builds work fine without them.
 *
 * To enable in production, add these as repo secrets:
 *   GTM_ID                         e.g. GTM-XXXXXXX
 *   DATADOG_RUM_APPLICATION_ID
 *   DATADOG_RUM_CLIENT_TOKEN
 *   DATADOG_RUM_SITE               defaults to datadoghq.com
 *   DATADOG_RUM_SERVICE            defaults to "kyletaylored-website"
 *   DATADOG_RUM_ENV                defaults to "production"
 *   DATADOG_RUM_VERSION            e.g. a git SHA or release tag — must
 *                                  match the sourcemap upload's release
 *                                  version (astro.config.mjs's
 *                                  @datadog/vite-plugin config) for
 *                                  Error Tracking to symbolicate stack
 *                                  traces against real source.
 *
 * GTM_ID is read via `process.env` (Node, build-time only) since it's just
 * inlined once into the static HTML. RUM is different: it's the actual
 * `@datadog/browser-rum` SDK (+ `@datadog/browser-rum-react` for our React
 * islands), imported and bundled by Vite like any other client script —
 * `define:vars` hands the build-time config into that bundle.
 */
const gtmId = process.env.GTM_ID;

const datadogRumConfig = process.env.DATADOG_RUM_APPLICATION_ID && process.env.DATADOG_RUM_CLIENT_TOKEN
	? {
			applicationId: process.env.DATADOG_RUM_APPLICATION_ID,
			clientToken: process.env.DATADOG_RUM_CLIENT_TOKEN,
			site: process.env.DATADOG_RUM_SITE || 'datadoghq.com',
			service: process.env.DATADOG_RUM_SERVICE || 'kyletaylored-website',
			env: process.env.DATADOG_RUM_ENV || 'production',
			version: process.env.DATADOG_RUM_VERSION || undefined,
			sessionSampleRate: 100,
			sessionReplaySampleRate: 20,
			trackResources: true,
			trackUserInteractions: true,
			trackLongTasks: true,
			defaultPrivacyLevel: 'mask-user-input',
		}
	: null;
---

{
	gtmId && (
		<script
			set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
		/>
	)
}

{
	datadogRumConfig && (
		<>
			{/*
				define:vars forces Astro to skip Vite/module bundling for this
				script (it becomes a plain inline script with the vars inlined as
				literal JS) — so `import` statements don't work inside it. Split
				config injection (this script) from the actual SDK import (the
				next script, which Vite *does* bundle) rather than combining them.
			*/}
			<script define:vars={{ datadogRumConfig }} is:inline>
				window.__DD_RUM_CONFIG__ = datadogRumConfig;
			</script>
			<script>
				import { datadogRum } from '@datadog/browser-rum';
				import { reactPlugin } from '@datadog/browser-rum-react';

				const config = (window as typeof window & { __DD_RUM_CONFIG__?: Record<string, unknown> })
					.__DD_RUM_CONFIG__;

				if (config) {
					datadogRum.init({
						...config,
						// No client-side router — this is a fully static multi-page site.
						plugins: [reactPlugin({ router: false })],
					} as Parameters<typeof datadogRum.init>[0]);
				}
			</script>
		</>
	)
}
