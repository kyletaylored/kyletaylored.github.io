---
interface Props {
	color?: string;
	size?: string;
	class?: string;
}

const { color = 'var(--color-yellow)', size = '48px', class: className } = Astro.props;
---

<svg
	class:list={['decor-triangle', className]}
	width={size}
	height={size}
	viewBox="0 0 100 100"
	aria-hidden="true"
>
	<polygon points="50,0 100,100 0,100" fill={color} />
</svg>
