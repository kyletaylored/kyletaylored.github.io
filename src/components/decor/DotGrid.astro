---
interface Props {
	color?: string;
	width?: string;
	height?: string;
	class?: string;
}

const { color = 'var(--color-border)', width = '100%', height = '120px', class: className } = Astro.props;
const patternId = `dot-grid-${Math.random().toString(36).slice(2, 9)}`;
---

<svg class:list={['decor-dot-grid', className]} width={width} height={height} aria-hidden="true">
	<defs>
		<pattern id={patternId} width="16" height="16" patternUnits="userSpaceOnUse">
			<circle cx="2" cy="2" r="1.5" fill={color} />
		</pattern>
	</defs>
	<rect width="100%" height="100%" fill={`url(#${patternId})`} />
</svg>
