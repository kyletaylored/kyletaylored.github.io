---
interface Props {
	colorA?: string;
	colorB?: string;
	width?: string;
	height?: string;
	class?: string;
}

const {
	colorA = 'var(--color-yellow)',
	colorB = 'var(--color-black)',
	width = '100%',
	height = '16px',
	class: className,
} = Astro.props;
---

<span
	class:list={['decor-hazard', className]}
	style={{
		width,
		height,
		background: `repeating-linear-gradient(45deg, ${colorA}, ${colorA} 10px, ${colorB} 10px, ${colorB} 20px)`,
	}}
	aria-hidden="true"
></span>

<style>
	.decor-hazard {
		display: block;
	}
</style>
