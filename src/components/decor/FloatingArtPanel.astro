---
// "Floating Art Panel — Mid-Section" from guidelines/Art Blocks.dc.html —
// "goes between content columns in a 2-up layout... creates visual
// rhythm between sections without a full dark hero." Meant to sit in a
// narrow middle column on light (#FAF8F3) backgrounds; hidden below `md`
// since there's no side-by-side layout to break up on mobile.
import Triangle from './Triangle.astro';
import Circle from './Circle.astro';
import Diamond from './Diamond.astro';
import DotGrid from './DotGrid.astro';
---

<div class="relative hidden h-[240px] w-full overflow-hidden md:block">
	<div class="pointer-events-none absolute left-0 top-2.5 opacity-20">
		<DotGrid width="50px" height="50px" />
	</div>
	<div class="pointer-events-none absolute left-5 top-0">
		<Triangle color="var(--color-teal)" size="120px" />
	</div>
	<div class="pointer-events-none absolute left-[60px] bottom-5">
		<Circle color="var(--color-pink)" size="120px" />
	</div>
	<div class="pointer-events-none absolute right-0 top-5">
		<Diamond color="var(--color-yellow)" size="14px" />
	</div>
</div>
