---
interface Props {
	color?: string;
	size?: string;
	class?: string;
}

const { color = 'var(--color-black)', size = '24px', class: className } = Astro.props;
---

<svg class:list={['decor-crosshair', className]} width={size} height={size} viewBox="0 0 24 24" aria-hidden="true">
	<circle cx="12" cy="12" r="9" fill="none" stroke={color} stroke-width="1.5" />
	<line x1="12" y1="0" x2="12" y2="24" stroke={color} stroke-width="1" />
	<line x1="0" y1="12" x2="24" y2="12" stroke={color} stroke-width="1" />
</svg>
