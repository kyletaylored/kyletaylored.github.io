---
interface Props {
	href: string;
	variant?: 'primary' | 'secondary' | 'dark' | 'dark-solid';
	target?: string;
	rel?: string;
	class?: string;
}

const { href, variant = 'primary', target, rel, class: className } = Astro.props;

const variants = {
	primary: 'border-teal bg-teal text-ink hover:bg-teal/80',
	secondary: 'border-ink bg-transparent text-ink hover:bg-muted',
	dark: 'border-bg bg-transparent text-bg hover:bg-bg/10',
	'dark-solid': 'border-teal bg-teal text-ink hover:bg-teal/80',
};
---

<a
	href={href}
	target={target}
	rel={rel}
	class:list={[
		'inline-flex items-center justify-center gap-2 border-2 px-5 py-3 font-body text-xs font-bold tracking-wider uppercase transition-colors',
		variants[variant],
		className,
	]}
>
	<slot />
</a>
