---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Button from '../components/Button.astro';
import Circle from '../components/decor/Circle.astro';
import Triangle from '../components/decor/Triangle.astro';

interface Props {
	entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { title, summary, heroImage, status, tags, links, stack, seo } = entry.data;
---

<BaseLayout
	title={seo.metaTitle ?? title}
	description={seo.metaDescription ?? summary}
	image={seo.ogImage ?? heroImage}
	canonicalUrl={seo.canonicalUrl}
	noindex={seo.noindex}
	jsonLd={seo.jsonLd}
>
	<header class="relative overflow-hidden bg-ink px-6 py-14 md:px-12 md:py-16">
		<div class="pointer-events-none absolute -top-8 right-10 hidden opacity-[0.12] md:block">
			<Circle color="var(--color-teal)" size="160px" />
		</div>
		<div class="pointer-events-none absolute right-10 top-10 hidden opacity-20 md:block">
			<Triangle color="var(--color-yellow)" size="70px" />
		</div>

		<div class="relative mx-auto max-w-[760px]">
			<div class="mb-4 text-xs font-semibold tracking-widest text-teal uppercase">{status}</div>
			<h1 class="mb-5 text-4xl leading-[1.05] font-bold tracking-tight text-bg md:text-5xl">{title}</h1>
			<p class="mb-6 max-w-[580px] text-lg leading-relaxed text-muted-light">{summary}</p>
			<div class="mb-7 flex flex-wrap gap-1.5">
				{stack.map((s) => <span class="rounded-full border border-border-dark px-2.5 py-0.5 text-[11px] text-muted">{s}</span>)}
			</div>
			<div class="mb-7 flex flex-wrap gap-1.5">
				{tags.map((tag) => <span class="rounded-full bg-surface-dark px-2.5 py-0.5 text-[11px] text-muted-light">{tag}</span>)}
			</div>
			<div class="flex flex-wrap gap-3">
				{links.caseStudy && <Button href={links.caseStudy} variant="primary">Read Case Study &rarr;</Button>}
				{
					links.source && (
						<Button href={links.source} variant="dark" target="_blank" rel="noopener noreferrer">
							View Source &rarr;
						</Button>
					)
				}
				{
					links.demo && (
						<Button href={links.demo} variant="dark" target="_blank" rel="noopener noreferrer">
							Launch Demo &rarr;
						</Button>
					)
				}
			</div>
		</div>
	</header>

	<div class="h-1 bg-pink"></div>

	{
		heroImage && (
			<div class="mx-auto max-w-4xl px-6 pt-10 md:px-12">
				{typeof heroImage === 'string' ? (
					<img src={heroImage} alt="" class="w-full rounded-md" />
				) : (
					<Picture formats={['avif', 'webp']} width={1200} height={600} src={heroImage} alt="" class="w-full rounded-md" />
				)}
			</div>
		)
	}

	<article class="prose mx-auto max-w-[760px] px-6 py-12 md:px-12">
		<slot />
	</article>
</BaseLayout>
