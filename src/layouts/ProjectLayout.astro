---
import { Picture } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Button from '../components/Button.astro';
import Circle from '../components/decor/Circle.astro';
import Triangle from '../components/decor/Triangle.astro';
import Diamond from '../components/decor/Diamond.astro';

interface Props {
	entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { title, summary, heroImage, status, tags, links, stack, featured, stats, features, lessons, seo } =
	entry.data;

const statusChip = {
	active: { label: 'Active Project', color: 'var(--color-teal)' },
	concept: { label: 'Concept', color: 'var(--color-yellow)' },
	archived: { label: 'Archived', color: 'var(--color-muted)' },
}[status];

const relatedArticles = (await getCollection('articles', ({ data }) => !data.draft))
	.filter((a) => a.data.tags.some((t) => tags.includes(t)))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

const moreProjects = (await getCollection('projects'))
	.filter((p) => p.id !== entry.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<BaseLayout
	title={seo.metaTitle ?? title}
	description={seo.metaDescription ?? summary}
	image={seo.ogImage ?? heroImage}
	canonicalUrl={seo.canonicalUrl}
	noindex={seo.noindex}
	jsonLd={seo.jsonLd}
>
	<header class="relative overflow-hidden bg-ink px-6 pt-14 md:px-12">
		<div class="pointer-events-none absolute -top-10 right-16 hidden opacity-[0.07] md:block">
			<Circle color="var(--color-teal)" size="220px" />
		</div>
		<div class="pointer-events-none absolute right-10 top-16 hidden opacity-20 md:block">
			<Triangle color="var(--color-yellow)" size="100px" />
		</div>
		<div class="pointer-events-none absolute bottom-16 right-10 hidden opacity-20 md:block">
			<Diamond color="var(--color-pink)" size="48px" />
		</div>

		<div class="relative mx-auto max-w-6xl">
			<div class="mb-7 flex items-center gap-2">
				<a href="/projects" class="text-xs font-medium tracking-wide text-muted uppercase">Projects</a>
				{
					tags[0] && (
						<>
							<span class="text-border-dark">&rsaquo;</span>
							<span class="text-xs font-medium tracking-wide text-teal uppercase">{tags[0]}</span>
						</>
					)
				}
			</div>

			<div class="grid gap-10 pb-8 lg:grid-cols-[1fr_360px] lg:items-end lg:gap-16">
				<div>
					{
						statusChip && (
							<div class="mb-6 inline-flex items-center gap-1.5 rounded-full border border-border-dark bg-surface-dark px-3 py-1.5">
								<span class="h-1.5 w-1.5 rounded-full" style={{ background: statusChip.color }} />
								<span class="font-mono text-[10px] tracking-wide" style={{ color: statusChip.color }}>
									{statusChip.label.toUpperCase()}
								</span>
							</div>
						)
					}
					<h1 class="mb-5 text-5xl leading-[0.95] font-bold tracking-tighter text-bg md:text-6xl">{title}</h1>
					<p class="mb-9 max-w-xl text-lg leading-relaxed text-muted-light">{summary}</p>
					<div class="flex flex-wrap gap-2.5">
						{links.caseStudy && <Button href={links.caseStudy} variant="primary">Read Write-up &rarr;</Button>}
						{
							links.source && (
								<Button href={links.source} variant="dark" target="_blank" rel="noopener noreferrer">
									View on GitHub &rarr;
								</Button>
							)
						}
						{
							links.demo && (
								<Button href={links.demo} variant="dark" target="_blank" rel="noopener noreferrer">
									Live Demo &rsaquo;
								</Button>
							)
						}
					</div>
				</div>

				{
					stats && (
						<div class="rounded-t-md border border-border-dark bg-[#0D0D0D] p-6">
							<div class="mb-5 font-mono text-[10px] font-bold tracking-wide text-muted uppercase">
								Project Stats
							</div>
							<div class="flex flex-col">
								{stats.stars && (
									<div class="flex items-center justify-between border-b border-border-dark py-2.5">
										<span class="text-xs text-muted">Stars</span>
										<span class="font-mono text-sm font-bold text-yellow">{stats.stars} &#9733;</span>
									</div>
								)}
								{stats.forks && (
									<div class="flex items-center justify-between border-b border-border-dark py-2.5">
										<span class="text-xs text-muted">Forks</span>
										<span class="font-mono text-sm text-bg">{stats.forks}</span>
									</div>
								)}
								{stats.lastCommit && (
									<div class="flex items-center justify-between border-b border-border-dark py-2.5">
										<span class="text-xs text-muted">Last commit</span>
										<span class="font-mono text-xs text-bg">{stats.lastCommit}</span>
									</div>
								)}
								{stats.license && (
									<div class="flex items-center justify-between border-b border-border-dark py-2.5">
										<span class="text-xs text-muted">License</span>
										<span class="font-mono text-xs text-bg">{stats.license}</span>
									</div>
								)}
								{stats.version && (
									<div class="flex items-center justify-between py-2.5">
										<span class="text-xs text-muted">Version</span>
										<span class="font-mono text-xs text-teal">{stats.version}</span>
									</div>
								)}
							</div>
							{tags.length > 0 && (
								<div class="mt-4 flex flex-wrap gap-1.5 border-t border-border-dark pt-4">
									{tags.map((tag) => (
										<span class="rounded-full border border-border-dark px-2.5 py-0.5 text-[10px] text-muted">{tag}</span>
									))}
								</div>
							)}
						</div>
					)
				}
			</div>
		</div>
	</header>

	<div class="h-1 bg-pink"></div>

	{
		heroImage && (
			<section class="bg-surface-dark px-6 py-10 md:px-12">
				<div class="mx-auto max-w-6xl overflow-hidden rounded-lg border border-border-dark">
					<div class="flex items-center gap-2.5 border-b border-border-dark bg-[#0D0D0D] px-5 py-3">
						<span class="h-3 w-3 rounded-full bg-red" />
						<span class="h-3 w-3 rounded-full bg-yellow" />
						<span class="h-3 w-3 rounded-full bg-teal" />
						<span class="ml-2 truncate font-mono text-[11px] text-muted">{title}</span>
					</div>
					{typeof heroImage === 'string' ? (
						<img src={heroImage} alt="" class="w-full" />
					) : (
						<Picture formats={['avif', 'webp']} width={1200} height={640} src={heroImage} alt="" class="w-full" />
					)}
				</div>
			</section>
		)
	}

	<div class="mx-auto grid max-w-6xl gap-16 px-6 py-16 md:px-12 md:py-20 lg:grid-cols-[1fr_300px] lg:items-start">
		<div>
			<div class="prose mb-14">
				<div class="mb-6 flex items-center gap-2 text-xs font-bold tracking-wide uppercase">
					<span class="h-1.5 w-1.5 rounded-full bg-red"></span>Overview
				</div>
				<slot />
			</div>

			{
				features.length > 0 && (
					<div class="mb-14">
						<div class="mb-6 flex items-center gap-2 text-xs font-bold tracking-wide uppercase">
							<span class="h-1.5 w-1.5 rounded-full bg-red" />Features
						</div>
						<div class="grid grid-cols-1 gap-0.5 sm:grid-cols-2">
							{features.map((f) => (
								<div class="flex gap-3.5 border border-border bg-white p-5">
									<div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md bg-ink">
										<span class="text-sm text-teal">{f.icon ?? '&#9670;'}</span>
									</div>
									<div>
										<div class="mb-1 text-sm font-bold">{f.title}</div>
										<div class="text-xs leading-relaxed text-muted">{f.description}</div>
									</div>
								</div>
							))}
						</div>
					</div>
				)
			}

			{
				lessons.length > 0 && (
					<div class="mb-14">
						<div class="mb-6 flex items-center gap-2 text-xs font-bold tracking-wide uppercase">
							<span class="h-1.5 w-1.5 rounded-full bg-red" />What I Learned
						</div>
						<div class="flex flex-col">
							{lessons.map((lesson, i) => (
								<div class="grid grid-cols-[28px_1fr] gap-4 border-b border-border py-5 last:border-b-0">
									<span class="pt-0.5 font-mono text-[11px] text-muted-light">{String(i + 1).padStart(2, '0')}</span>
									<div>
										<div class="mb-1.5 text-sm font-semibold">{lesson.title}</div>
										<p class="m-0 text-sm text-muted">{lesson.description}</p>
									</div>
								</div>
							))}
						</div>
					</div>
				)
			}

			{
				relatedArticles.length > 0 && (
					<div>
						<div class="mb-5 flex items-center gap-2 text-xs font-bold tracking-wide uppercase">
							<span class="h-1.5 w-1.5 rounded-full bg-red" />Related Write-ups
						</div>
						<div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
							{relatedArticles.map((a) => (
								<a href={`/articles/${a.id}/`} class="block rounded-md border border-border bg-white p-5">
									<div class="mb-2 text-[10px] font-semibold tracking-wide text-teal uppercase">Article</div>
									<div class="mb-1.5 text-sm leading-snug font-semibold text-ink">{a.data.title}</div>
								</a>
							))}
						</div>
					</div>
				)
			}
		</div>

		<aside class="flex flex-col gap-6 lg:sticky lg:top-20">
			<div class="rounded-md border border-border bg-white p-5">
				<div class="mb-4 text-[11px] font-bold tracking-wide text-ink uppercase">Links</div>
				<div class="flex flex-col gap-2">
					{links.source && (
						<a href={links.source} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 border border-border bg-bg px-3 py-2.5 text-xs font-semibold text-ink">
							&#8853; GitHub repo &rarr;
						</a>
					)}
					{links.demo && (
						<a href={links.demo} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 border border-teal bg-teal px-3 py-2.5 text-xs font-semibold text-ink">
							&#9654; Live demo &rarr;
						</a>
					)}
				</div>
			</div>

			{
				stack.length > 0 && (
					<div class="rounded-md border border-border bg-white p-5">
						<div class="mb-3.5 text-[11px] font-bold tracking-wide text-ink uppercase">Built with</div>
						<div class="flex flex-col gap-1.5">
							{stack.map((s, i) => (
								<div class={`flex items-center justify-between py-1.5 ${i < stack.length - 1 ? 'border-b border-surface' : ''}`}>
									<span class="text-xs">{s}</span>
									{i === 0 && (
										<span class="rounded-full bg-teal px-2 py-0.5 text-[10px] font-semibold text-ink">Primary</span>
									)}
								</div>
							))}
						</div>
					</div>
				)
			}

			{
				moreProjects.length > 0 && (
					<div>
						<div class="mb-3 text-[11px] font-bold tracking-wide text-ink uppercase">More projects</div>
						<div class="flex flex-col gap-2">
							{moreProjects.map((p) => (
								<a href={`/projects/${p.id}/`} class="flex items-center gap-3 rounded-md border border-border bg-white p-3">
									<div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md bg-ink">
										<span class="text-xs text-yellow">&#11043;</span>
									</div>
									<div>
										<div class="text-xs font-semibold text-ink">{p.data.title}</div>
									</div>
									<span class="ml-auto text-xs text-muted-light">&rarr;</span>
								</a>
							))}
						</div>
					</div>
				)
			}
		</aside>
	</div>
</BaseLayout>

<style>
	.prose :global(p) {
		font-size: 16px;
		line-height: 1.7;
		color: var(--color-black);
		margin: 0 0 20px;
	}
	.prose :global(p:first-of-type) {
		font-size: 18px;
		font-weight: 500;
		line-height: 1.65;
		border-left: 3px solid var(--color-teal);
		padding-left: 20px;
	}
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 13px;
	}
</style>
