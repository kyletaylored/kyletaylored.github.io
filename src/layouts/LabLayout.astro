---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string[];
	jsonLd?: Record<string, unknown>;
}

const { title, description, image, keywords, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} keywords={keywords} jsonLd={jsonLd}>
	<header class="relative overflow-hidden bg-ink px-6 py-14 md:px-12 md:py-16">
		<div class="relative mx-auto max-w-[760px]">
			<slot name="hero" />
		</div>
	</header>
	<div class="h-1 bg-pink"></div>
	<div class="mx-auto max-w-[760px] px-6 py-12 md:px-12">
		<slot />
	</div>
</BaseLayout>
