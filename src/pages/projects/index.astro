---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import LightSectionArt from '../../components/decor/LightSectionArt.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Projects" description="Methodology, source, and live demos for everything I've built." image="/og/projects.png">
	<PageHeader
		eyebrow="Portfolio"
		title="Projects"
		description="Methodology, source code, and live demos for everything I've built."
	/>
	<div class="relative mx-auto max-w-6xl overflow-hidden px-6 py-12 md:px-12">
		<LightSectionArt />
		<div class="relative grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
			{
				projects.map((p) => {
					const isRole = p.data.kind === 'role';
					const statusLabel = isRole
						? p.data.status === 'active'
							? 'Current Role'
							: 'Past Role'
						: p.data.status;
					const accentColor = p.data.brandColor ?? 'var(--color-teal)';
					return (
						<a
							href={`/projects/${p.id}/`}
							class="flex flex-col gap-3 rounded-md border border-border bg-white p-5 transition-colors hover:border-teal"
							style={isRole ? { borderLeft: `3px solid ${accentColor}` } : undefined}
						>
							<div class="text-xs font-semibold tracking-wide text-muted uppercase">{statusLabel}</div>
							<h2 class="text-lg font-bold text-ink">{p.data.title}</h2>
							{isRole && p.data.role && <div class="text-sm font-semibold" style={{ color: accentColor }}>{p.data.role}</div>}
							<p class="text-sm leading-relaxed text-muted">{p.data.summary}</p>
							<div class="mt-auto flex flex-wrap gap-1.5 pt-2">
								{p.data.stack.map((s) => (
									<span class="rounded-full bg-surface px-2.5 py-0.5 text-[11px] text-muted">{s}</span>
								))}
							</div>
						</a>
					);
				})
			}
		</div>
	</div>
</BaseLayout>
