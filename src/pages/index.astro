---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TerminalWindow from '../components/lab/TerminalWindow.astro';
import GitHubContributionGraph from '../components/GitHubContributionGraph.astro';
import ArticleTeaserCard from '../components/ArticleTeaserCard.astro';
import ParallaxSection from '../components/ParallaxSection.astro';
import FloatingArtPanel from '../components/decor/FloatingArtPanel.astro';
import site from '../data/site.json';
import { AUTHOR_GRAVATAR_HASH, AUTHOR_NAME } from '../consts';

const categories = [
	{ href: '/projects', label: 'Projects', desc: 'Things I\'ve built, from idea to shipped.', icon: '>_', mono: true, color: 'var(--color-teal)' },
	{ href: '/articles', label: 'Articles', desc: 'Writeups, notes, and deep dives.', icon: '</>', mono: true, color: 'var(--color-pink)' },
	{ href: '/lab', label: 'Lab', desc: 'Experiments, tools, and playground builds.', icon: '⬡', color: 'var(--color-yellow)' },
	{ href: '/about', label: 'About', desc: 'Who I am and what I\'m up to.', icon: '◈', color: 'var(--color-blue)' },
];

const featuredProjects = (await getCollection('projects', ({ data }) => data.featured))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const contributionWeeks = (await import('../data/contributions.json')).default as {
	days: { date: string; count: number }[];
}[];
---

<BaseLayout title={site.siteTitle} description={site.siteDescription} image="/og/home.png">
	<ParallaxSection variant="dark" eyebrow="Build weird things.">
		<Fragment slot="heading">
			<h1 class="mb-6 text-5xl leading-[1.0] font-bold tracking-tight text-bg md:text-7xl">
				Hi, I'm <span class="text-teal">Kyle</span><span class="text-pink">.</span>
			</h1>
		</Fragment>

		<div class="grid items-center gap-10 lg:grid-cols-[1fr_420px] lg:gap-16">
			<div>
				<p class="mb-3 max-w-md text-base leading-relaxed text-muted-light">
					A technical guy with ADHD coming up with super weird projects and tinkering with everything in my Lab.
				</p>
				<p class="mb-9 font-medium text-teal">This site documents the journey.</p>
				<div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
					<Button href="/projects" variant="primary">Browse Projects &rarr;</Button>
					<Button href="/lab" variant="dark">Visit the Lab &rsaquo;</Button>
				</div>

				<div class="mt-6 flex max-w-sm items-start gap-3">
					<div class="w-[2px] flex-shrink-0 self-stretch rounded-full bg-teal opacity-40"></div>
					<p class="text-sm leading-relaxed text-muted italic">
						most of what's here started as a distraction from something else I was supposed to be doing.
					</p>
				</div>
			</div>

			<TerminalWindow title="~ kyletaylored.com">
				<span class="text-teal">~ $</span> whoami
				{'\n\n'}
				<span class="text-teal">Name</span>       Kyle Taylor
				{'\n'}
				<span class="text-teal">Role</span>       Solutions Engineer
				{'\n'}
				<span class="text-teal">Stack</span>      Pancakes, Pogs, and Legos
				{'\n'}
				<span class="text-teal">Location</span>   Denton, Texas
				{'\n'}
				<span class="text-teal">Focus</span>      AI &middot; Hardware &middot; Open Source
				{'\n'}
				<span class="text-teal">Status</span>     Compiling...
				{'\n\n'}
				<span class="text-teal">~ $</span>
			</TerminalWindow>
		</div>
	</ParallaxSection>

	<div class="h-1 bg-pink"></div>

	<section class="mx-auto max-w-6xl px-6 py-12 md:px-12">
		<SectionHeader label="Explore" linkText={null} />
		<div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
			{
				categories.map((cat) => (
					<a
						href={cat.href}
						class="flex cursor-pointer flex-col gap-3 rounded-md border border-border bg-white p-5 transition-colors hover:border-teal"
					>
						<div class="flex h-12 w-12 items-center justify-center rounded-lg bg-ink">
							<span class:list={['text-lg font-bold', cat.mono && 'font-mono']} style={{ color: cat.color }}>
								{cat.icon}
							</span>
						</div>
						<div>
							<div class="mb-1.5 text-xs font-bold tracking-wide uppercase">{cat.label}</div>
							<div class="text-xs leading-relaxed text-muted">{cat.desc}</div>
						</div>
						<div class="mt-auto text-base">&rarr;</div>
					</a>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-12 md:px-12">
		<div class="grid items-center gap-10 md:grid-cols-[280px_1fr] md:gap-14">
			<div class="relative mx-auto w-full max-w-[280px]">
				<div class="pointer-events-none absolute -top-3 -right-3 h-full w-full rounded-md bg-teal opacity-20"></div>
				<img
					src={`https://www.gravatar.com/avatar/${AUTHOR_GRAVATAR_HASH}?s=480&d=identicon`}
					alt={AUTHOR_NAME}
					width="480"
					height="480"
					class="relative aspect-square w-full rounded-md border-2 border-border-dark bg-surface-dark object-cover"
				/>
			</div>
			<div>
				<div class="mb-4 flex items-center gap-2 text-xs font-bold tracking-wide text-red uppercase">
					<span class="h-1.5 w-1.5 rounded-full bg-red"></span>
					A Little About Me
				</div>
				<p class="mb-5 max-w-xl text-lg leading-relaxed text-ink">
					I've been making things since before I knew what to call it — taking apart electronics I
					shouldn't have, writing scripts to automate things that probably didn't need automating.
					These days it's software, AI systems, and hardware, but the instinct hasn't changed.
				</p>
				<a href="/about" class="inline-flex items-center gap-1.5 text-sm font-semibold text-teal">
					More about me &rarr;
				</a>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-12 md:px-12">
		<SectionHeader label="From the Lab" linkText={null} />
		<div class="grid grid-cols-1 gap-2 sm:grid-cols-[2fr_1fr_1fr_1fr] sm:h-[280px]">
			<div class="flex aspect-[4/3] items-center justify-center border border-dashed border-border bg-surface p-4 text-center sm:aspect-auto sm:h-full">
				<span class="font-mono text-[11px] text-muted">Add: workshop bench photo</span>
			</div>
			<div class="flex aspect-[4/3] items-center justify-center border border-dashed border-border bg-surface p-4 text-center sm:aspect-auto sm:h-full">
				<span class="font-mono text-[11px] text-muted">Add: hardware / circuit close-up</span>
			</div>
			<div class="flex aspect-[4/3] items-center justify-center border border-dashed border-border bg-surface p-4 text-center sm:aspect-auto sm:h-full">
				<span class="font-mono text-[11px] text-muted">Add: build-in-progress shot</span>
			</div>
			<div class="flex flex-col justify-between bg-ink p-5">
				<div class="text-3xl leading-none font-bold text-teal">&ldquo;</div>
				<p class="text-sm leading-relaxed text-bg italic">
					The best tools are the ones you built because nothing else did what you needed.
				</p>
				<div class="text-[10px] font-semibold tracking-wide text-muted-light uppercase">&mdash; K.T.</div>
			</div>
		</div>
	</section>

	<ParallaxSection variant="split" eyebrow="Always Building">
		<Fragment slot="heading">
			<h2 class="mb-5 text-4xl leading-[1.05] font-bold tracking-tight text-bg">
				New experiments,<br />every week.
			</h2>
		</Fragment>
		<p class="mb-8 max-w-sm text-base leading-relaxed text-muted-light">
			The Lab is where half-finished ideas go to become something real &mdash; software, hardware, and
			everything in between. New builds land there before anywhere else.
		</p>
		<Button href="/lab" variant="dark">Explore the Lab &rarr;</Button>
	</ParallaxSection>

	{
		featuredProjects.length > 0 && (
			<section class="mx-auto max-w-6xl px-6 py-12 md:px-12">
				<SectionHeader label="Featured Projects" linkText="View all projects" linkHref="/projects" />
				<div class="flex gap-3 overflow-x-auto pb-2 sm:grid sm:grid-cols-3 sm:overflow-visible sm:pb-0 lg:grid-cols-5">
					{featuredProjects.map((p) => (
						<div class="w-[220px] flex-shrink-0 sm:w-auto">
							<ArticleTeaserCard entry={p} variant="featured" />
						</div>
					))}
				</div>
			</section>
		)
	}

	<section class="mx-auto grid max-w-6xl gap-8 px-6 py-12 md:px-12 lg:grid-cols-[1fr_1.6fr]">
		<div>
			<SectionHeader label="GitHub Activity" linkText={null} />
			<GitHubContributionGraph weeks={contributionWeeks} profileUrl="https://github.com/kyletaylored" />
		</div>

		<div class="relative overflow-hidden">
			<FloatingArtPanel class="pointer-events-none absolute inset-0 hidden opacity-[0.15] md:block" />
			<div class="relative">
				<SectionHeader label="Latest Articles" linkText="View all articles" linkHref="/articles" />
				{
					latestArticles.length > 0 ? (
						<div class="flex flex-col gap-3">
							{latestArticles.map((a) => (
								<ArticleTeaserCard entry={a} variant="compact" />
							))}
						</div>
					) : (
						<p class="text-sm text-muted">No articles published yet.</p>
					)
				}
			</div>
		</div>
	</section>
</BaseLayout>
