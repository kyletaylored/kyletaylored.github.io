---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import site from '../data/site.json';

const featuredProjects = (await getCollection('projects', ({ data }) => data.featured))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

let activity: { type: string; repo: string; title: string; url: string; date: string }[] = [];
try {
	activity = (await import('../data/activity.json')).default;
} catch {
	activity = [];
}
---

<BaseLayout title={site.siteTitle} description={site.siteDescription}>
	<section class="hero">
		<h1>{site.siteTitle}</h1>
		<p>{site.siteDescription}</p>
	</section>

	{
		featuredProjects.length > 0 && (
			<section>
				<h2>Featured Projects</h2>
				<ul class="grid">
					{featuredProjects.map((p) => (
						<li>
							<a href={`/projects/${p.id}/`}>
								<h3>{p.data.title}</h3>
								<p>{p.data.summary}</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		latestArticles.length > 0 && (
			<section>
				<h2>Latest Articles</h2>
				<ul class="grid">
					{latestArticles.map((a) => (
						<li>
							<a href={`/articles/${a.id}/`}>
								<h3>{a.data.title}</h3>
								<p class="meta">
									<FormattedDate date={a.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		activity.length > 0 && (
			<section>
				<h2>Recent Activity</h2>
				<ul class="activity-list">
					{activity.slice(0, 8).map((item) => (
						<li>
							<a href={item.url} target="_blank" rel="noopener noreferrer">
								<span class="activity-type">{item.type}</span> {item.title}
							</a>
							<span class="activity-repo">{item.repo}</span>
						</li>
					))}
				</ul>
			</section>
		)
	}
</BaseLayout>

<style>
	.hero {
		text-align: center;
		padding: 2em 0;
	}
	.grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.5em;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}
	.grid li {
		padding: 1.5em;
		border: 1px solid var(--color-border);
		border-radius: 12px;
	}
	.grid a {
		text-decoration: none;
		color: inherit;
	}
	.meta {
		color: var(--color-muted);
		font-size: 0.9em;
	}
	.activity-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.activity-list li {
		display: flex;
		justify-content: space-between;
		padding: 0.5em 0;
		border-bottom: 1px solid var(--color-border);
	}
	.activity-type {
		text-transform: uppercase;
		font-size: 0.75em;
		color: var(--color-muted);
	}
	.activity-repo {
		color: var(--color-muted);
		font-size: 0.85em;
	}
</style>
