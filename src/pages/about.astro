---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing src/content/pages/about.mdx');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.seo.metaTitle ?? entry.data.title} description={entry.data.description}>
	<article class="prose">
		<h1>{entry.data.title}</h1>
		<Content />
	</article>
</BaseLayout>
