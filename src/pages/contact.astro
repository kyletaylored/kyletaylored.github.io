---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Circle from '../components/decor/Circle.astro';
import Triangle from '../components/decor/Triangle.astro';
import Diamond from '../components/decor/Diamond.astro';
import SocialIcon from '../components/icons/SocialIcon.astro';
import { CONTACT_EMAIL, FORMSPREE_FORM_ID } from '../consts';
import { currentlyBuilding } from '../data/currently-building';

const entry = await getEntry('pages', 'contact');
if (!entry) throw new Error('Missing src/content/pages/contact.mdx');

// Per Contact.dc.html: bespoke page, not data-driven — these sections
// aren't part of any content collection schema. Edit copy directly here.
const whatToExpect = [
	{ title: 'Personal reply', desc: "Every message is read and replied to by me, not a VA or template." },
	{ title: '2–3 day turnaround', desc: "Usually faster. Occasionally slower if I'm deep in a build." },
	{ title: 'Honest answers', desc: "If I can't help or it's not a fit, I'll say so directly." },
];

const directLinks = [
	{ platform: null, label: 'Email', handle: CONTACT_EMAIL, cta: 'Write', href: `mailto:${CONTACT_EMAIL}` },
	{ platform: 'threads' as const, label: 'Threads', handle: '@kyletaylored', cta: 'Follow', href: 'https://www.threads.net/@kyletaylored' },
	{ platform: 'github' as const, label: 'GitHub', handle: 'kyletaylored', cta: 'Star something', href: 'https://github.com/kyletaylored' },
];
---

<BaseLayout title={entry.data.seo.metaTitle ?? entry.data.title} description={entry.data.description} image="/og/contact.png">
	<header class="relative overflow-hidden bg-ink px-6 py-16 md:px-12 md:py-20">
		<div class="pointer-events-none absolute right-20 -top-10 hidden opacity-[0.09] md:block">
			<Circle color="var(--color-pink)" size="200px" />
		</div>
		<div class="pointer-events-none absolute right-[220px] top-5 hidden opacity-10 lg:block">
			<Triangle color="var(--color-yellow)" size="96px" />
		</div>
		<div class="pointer-events-none absolute right-16 bottom-8 hidden opacity-[0.12] md:block">
			<Diamond color="var(--color-teal)" size="44px" />
		</div>
		<div class="pointer-events-none absolute left-6 bottom-6 hidden font-mono text-lg tracking-[6px] text-border-dark md:block">/ / / /</div>

		<div class="relative mx-auto max-w-[1200px]">
			<div class="mb-5 text-xs font-semibold tracking-widest text-teal uppercase">Let's talk</div>
			<h1 class="mb-5 text-6xl leading-[0.95] font-bold tracking-tighter text-bg md:text-7xl">
				Get in<br />touch<span class="text-pink">.</span>
			</h1>
			<p class="max-w-[480px] text-base leading-relaxed text-muted-light">
				I'm always up for interesting problems, collaborations, and conversations. I try to respond to
				everything within a few days.
			</p>
		</div>
	</header>
	<div class="h-1 bg-pink"></div>

	<div class="mx-auto grid max-w-[1200px] gap-16 px-6 py-16 md:px-12 lg:grid-cols-[1fr_380px] lg:gap-20">
		<div>
			<div class="mb-8 flex items-center gap-2.5">
				<span class="h-[7px] w-[7px] rounded-full bg-red"></span>
				<span class="text-[13px] font-bold tracking-wide uppercase">Send a message</span>
			</div>

			{
				FORMSPREE_FORM_ID === 'REPLACE_ME' && (
					<p class="mb-6 border border-yellow bg-yellow/10 px-4 py-3 text-xs text-muted">
						Form isn't wired up to Formspree yet — set FORMSPREE_FORM_ID in src/consts.ts.
					</p>
				)
			}

			<form action={`https://formspree.io/f/${FORMSPREE_FORM_ID}`} method="POST" class="flex flex-col gap-5">
				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
					<div class="flex flex-col gap-1.5">
						<label for="name" class="text-[11px] font-bold tracking-wide uppercase">Your name</label>
						<input
							id="name"
							name="name"
							type="text"
							required
							placeholder="Kyle Taylor"
							class="w-full border border-border bg-white px-4 py-3 text-sm text-ink transition-colors focus:border-teal focus:outline-none"
						/>
					</div>
					<div class="flex flex-col gap-1.5">
						<label for="email" class="text-[11px] font-bold tracking-wide uppercase">Email address</label>
						<input
							id="email"
							name="email"
							type="email"
							required
							placeholder="you@example.com"
							class="w-full border border-border bg-white px-4 py-3 text-sm text-ink transition-colors focus:border-teal focus:outline-none"
						/>
					</div>
				</div>

				<div class="flex flex-col gap-1.5">
					<span class="text-[11px] font-bold tracking-wide uppercase">What's this about?</span>
					<div class="flex flex-wrap gap-2">
						{
							['Collaboration', 'Project work', 'Just saying hi', 'Something else'].map((reason, i) => (
								<label class:list={[
									'flex cursor-pointer items-center gap-2 border px-4 py-2.5',
									i === 0 ? 'border-teal bg-teal/10' : 'border-border bg-white',
								]}>
									<input type="radio" name="reason" value={reason} checked={i === 0} class="accent-teal" />
									<span class="text-xs font-semibold">{reason}</span>
								</label>
							))
						}
					</div>
				</div>

				<div class="flex flex-col gap-1.5">
					<label for="message" class="text-[11px] font-bold tracking-wide uppercase">Message</label>
					<textarea
						id="message"
						name="message"
						rows="6"
						required
						placeholder="What's on your mind?"
						class="w-full resize-y border border-border bg-white px-4 py-3.5 text-sm leading-relaxed text-ink transition-colors focus:border-teal focus:outline-none"
					></textarea>
					<div class="text-[11px] text-muted-light">
						No pitch decks. No recruiters. Nothing is off-limits, but everything is read personally.
					</div>
				</div>

				<div class="flex items-center gap-4">
					<button
						type="submit"
						class="inline-flex items-center gap-2 border-2 border-teal bg-teal px-7 py-3.5 text-xs font-bold tracking-wide uppercase text-ink transition-colors hover:bg-teal/80"
					>
						Send message &rarr;
					</button>
					<span class="text-xs text-muted-light">Usually replies within 2–3 days.</span>
				</div>
			</form>

			<div class="my-10 flex items-center gap-4">
				<div class="h-px flex-1 bg-border"></div>
				<span class="text-[11px] font-semibold tracking-wide text-muted-light uppercase">Or reach out directly</span>
				<div class="h-px flex-1 bg-border"></div>
			</div>

			<div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
				{
					directLinks.map((link) => (
						<a
							href={link.href}
							target="_blank"
							rel="noopener noreferrer"
							class="flex flex-col gap-1.5 rounded-md border border-border bg-white p-4"
						>
							<div class="text-ink">
								{link.platform ? <SocialIcon platform={link.platform} size="20px" /> : <span class="text-lg">@</span>}
							</div>
							<div class="text-xs font-semibold text-ink">{link.label}</div>
							<div class="font-mono text-[11px] text-muted">{link.handle}</div>
							<div class="mt-0.5 text-[11px] text-teal">{link.cta} &rarr;</div>
						</a>
					))
				}
			</div>
		</div>

		<aside class="flex flex-col gap-6 lg:sticky lg:top-20 lg:self-start">
			<div class="relative overflow-hidden rounded-md bg-ink p-6">
				<div class="pointer-events-none absolute -right-4 -top-4 h-20 w-20 rounded-full bg-teal opacity-10"></div>
				<div class="relative mb-4 text-[11px] font-bold tracking-wide text-muted uppercase">Availability</div>
				<div class="relative mb-2.5 flex items-center gap-2.5">
					<span class="h-2.5 w-2.5 flex-shrink-0 rounded-full bg-teal"></span>
					<span class="text-[15px] font-semibold text-bg">Open to collaboration</span>
				</div>
				<p class="relative mb-4 text-[13px] leading-relaxed text-muted">
					Currently taking on interesting side projects and open source collaborations. Not available for
					full-time roles.
				</p>
				<div class="relative flex flex-col gap-1.5">
					<div class="flex items-center gap-2">
						<span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-teal"></span>
						<span class="text-xs text-muted-light">AI / agent systems</span>
					</div>
					<div class="flex items-center gap-2">
						<span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-teal"></span>
						<span class="text-xs text-muted-light">Open source contributions</span>
					</div>
					<div class="flex items-center gap-2">
						<span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-teal"></span>
						<span class="text-xs text-muted-light">Hardware + firmware</span>
					</div>
					<div class="flex items-center gap-2">
						<span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-red"></span>
						<span class="text-xs text-muted line-through">Full-time roles</span>
					</div>
				</div>
			</div>

			<div class="rounded-md border border-border bg-white p-5">
				<div class="mb-4 text-[11px] font-bold tracking-wide uppercase">What to expect</div>
				<div class="flex flex-col">
					{
						whatToExpect.map((item, i) => (
							<div
								class:list={[
									'grid grid-cols-[28px_1fr] gap-2.5 py-2.5',
									i < whatToExpect.length - 1 && 'border-b border-surface',
								]}
							>
								<span class="pt-0.5 font-mono text-[10px] text-muted-light">{String(i + 1).padStart(2, '0')}</span>
								<div>
									<div class="mb-0.5 text-xs font-semibold">{item.title}</div>
									<div class="text-xs leading-relaxed text-muted">{item.desc}</div>
								</div>
							</div>
						))
					}
				</div>
			</div>

			<div class="rounded-md border border-border bg-bg p-5">
				<div class="mb-3 flex items-center gap-2 text-[11px] font-bold tracking-wide uppercase">
					<span class="h-1.5 w-1.5 rounded-full bg-red"></span>
					Currently building
				</div>
				<div class="flex flex-col gap-2">
					{
						currentlyBuilding.map((item) => (
							<div class="flex items-center gap-2 text-[13px]">
								<span class="text-[10px]" style={{ color: item.color }}>&#9654;</span>
								{item.title}
							</div>
						))
					}
				</div>
			</div>
		</aside>
	</div>
</BaseLayout>
