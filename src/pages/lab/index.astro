---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import TerminalWindow from '../../components/lab/TerminalWindow.astro';
import ArticleTeaserCard from '../../components/ArticleTeaserCard.astro';
import HeroArt from '../../components/decor/HeroArt.astro';
import LightSectionArt from '../../components/decor/LightSectionArt.astro';

const entries = await getCollection('lab');

// Per Lab Home v2.dc.html: the "Explore the Lab" grid now includes a 6th
// tile linking out to /articles, alongside the 5 real labCategory values.
// Each of the 5 category tiles links to a same-page anchor (#experiments,
// #tools, etc.) — the section below with matching `id` renders that
// category's actual entries, filtered from the `lab` collection, so the
// anchor always resolves to real content instead of nowhere.
const categories = [
	{ key: 'experiments', label: 'Experiments', desc: 'Small projects, big ideas.', icon: '>_', mono: true, color: 'var(--color-teal)' },
	{ key: 'tools', label: 'Tools', desc: 'Useful utilities.', icon: '✕', color: 'var(--color-yellow)' },
	{ key: 'playground', label: 'Playground', desc: 'Tinker and learn.', icon: '</>', mono: true, color: 'var(--color-pink)' },
	{ key: 'ai', label: 'AI Lab', desc: 'Agents and models.', icon: '◈', color: 'var(--color-blue)' },
	{ key: 'hardware', label: 'Hardware', desc: 'Electronics, firmware.', icon: '⬡', color: 'var(--color-red)' },
] as const;

const categoryByKey = Object.fromEntries(categories.map((c) => [c.key, c]));
const allEntries = [...entries].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<BaseLayout title="Maker Lab" description="A playground for ideas, experiments, and side projects." image="/og/lab.png">
	<section class="relative overflow-hidden bg-ink px-6 py-16 md:px-12 md:py-20">
		<HeroArt />

		<div class="relative mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-[1fr_420px] lg:gap-16">
			<div>
				<div class="mb-5 text-xs font-semibold tracking-widest text-teal uppercase">
					Ideate. Tinker. Build. Think. Forget. Repeat.
				</div>
				<h1 class="mb-6 text-5xl leading-[1.0] font-bold tracking-tight text-bg md:text-7xl">
					Welcome to<br />the <span class="text-teal">Lab</span><span class="text-pink">.</span>
				</h1>
				<p class="mb-3 max-w-md text-base leading-relaxed text-muted-light">
					A playground for ideas, experiments, and side projects. Nothing here is perfect.
				</p>
				<p class="mb-9 font-medium text-teal">Everything here is in progress.</p>
				<div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
					<a
						href="#experiments"
						data-lab-filter="experiments"
						class="inline-flex items-center justify-center gap-2 border-2 border-teal bg-teal px-5 py-3 font-body text-xs font-bold tracking-wider uppercase text-ink transition-colors hover:bg-teal/80"
					>
						Browse Experiments &rarr;
					</a>
					<a
						href="#tools"
						data-lab-filter="tools"
						class="inline-flex items-center justify-center gap-2 border-2 border-bg bg-transparent px-5 py-3 font-body text-xs font-bold tracking-wider uppercase text-bg transition-colors hover:bg-bg/10"
					>
						View All Tools &rsaquo;
					</a>
				</div>
			</div>

			<TerminalWindow title="~ lab">
				<span class="text-teal">~ lab $</span> neofetch
				{'\n\n'}
				<span class="text-teal">OS</span>          kyletaylor.dev OS
				{'\n'}
				<span class="text-teal">Shell</span>       zsh
				{'\n'}
				<span class="text-teal">Editor</span>      VS Code
				{'\n'}
				<span class="text-teal">Lang</span>        TypeScript
				{'\n'}
				<span class="text-teal">Framework</span>   Astro
				{'\n'}
				<span class="text-teal">Uptime</span>      24/7
				{'\n'}
				<span class="text-teal">Location</span>    The Lab
				{'\n\n'}
				<span class="text-teal">~ lab $</span>
			</TerminalWindow>
		</div>
	</section>

	<div class="h-1 bg-pink"></div>

	<section id="explore" class="mx-auto max-w-6xl px-6 pt-12 md:px-12">
		<SectionHeader label="Explore the Lab" linkText={null} />
		<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
			{
				categories.map((cat) => (
					<a
						href={`#${cat.key}`}
						data-lab-filter={cat.key}
						class="flex cursor-pointer flex-col gap-3 rounded-md border border-border bg-white p-5 transition-colors hover:border-teal"
					>
						<div class="flex h-11 w-11 items-center justify-center rounded-lg bg-ink">
							<span class:list={['text-base font-bold', cat.mono && 'font-mono']} style={{ color: cat.color }}>
								{cat.icon}
							</span>
						</div>
						<div>
							<div class="mb-1.5 text-[11px] font-bold tracking-wide uppercase">{cat.label}</div>
							<div class="text-sm leading-relaxed text-muted">{cat.desc}</div>
						</div>
						<div class="mt-auto text-sm">&rarr;</div>
					</a>
				))
			}
			<a
				href="/articles"
				class="flex cursor-pointer flex-col gap-3 rounded-md border border-border bg-white p-5 transition-colors hover:border-teal"
			>
				<div class="flex h-11 w-11 items-center justify-center rounded-lg bg-ink">
					<span class="text-base font-bold" style={{ color: 'var(--color-pink)' }}>&#10022;</span>
				</div>
				<div>
					<div class="mb-1.5 text-[11px] font-bold tracking-wide uppercase">Articles</div>
					<div class="text-sm leading-relaxed text-muted">Writing and write-ups.</div>
				</div>
				<div class="mt-auto text-sm">&rarr;</div>
			</a>
		</div>
	</section>

	<section id="lab-grid" class="relative mx-auto max-w-6xl overflow-hidden px-6 pt-10 md:px-12">
		<LightSectionArt />
		<SectionHeader label="Everything in the Lab" linkText={null} />

		<div class="relative mb-5 flex flex-wrap gap-2">
			<button
				type="button"
				data-lab-filter="all"
				class="border border-teal bg-teal/10 px-4 py-2 text-xs font-semibold whitespace-nowrap"
			>
				All
			</button>
			{
				categories.map((cat) => (
					<button
						type="button"
						data-lab-filter={cat.key}
						class="border border-border bg-white px-4 py-2 text-xs font-semibold whitespace-nowrap"
					>
						{cat.label}
					</button>
				))
			}
		</div>

		<div id="lab-cards" class="relative grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
			{
				allEntries.map((item) => {
					const cat = categoryByKey[item.data.labCategory];
					return (
						<div data-lab-card data-category={item.data.labCategory} class="flex flex-col gap-3 rounded-md border border-border bg-white p-4">
							<div class="flex items-center gap-3">
								<div class="grid h-[34px] w-[34px] flex-shrink-0 grid-cols-2 gap-0.5 rounded-md bg-ink p-1">
									<div class="rounded-[1px] bg-teal" />
									<div class="rounded-[1px] bg-pink" />
									<div class="rounded-[1px] bg-yellow" />
									<div class="rounded-[1px] bg-blue" />
								</div>
								<div class="min-w-0 flex-1">
									<div class="truncate text-sm font-semibold">{item.data.title}</div>
									<span
										class="mt-0.5 inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase"
										style={{ color: cat?.color, background: 'color-mix(in srgb, currentColor 12%, transparent)' }}
									>
										{cat?.label}
									</span>
								</div>
							</div>
							<div class="line-clamp-2 text-sm leading-relaxed text-muted">{item.data.description}</div>
							<a
								href={`/lab/${item.id}/`}
								class="self-start border border-border px-3 py-1 text-[10px] font-semibold whitespace-nowrap"
							>
								Open
							</a>
						</div>
					);
				})
			}
		</div>
		<p id="lab-empty" class="hidden text-sm text-muted">Nothing here yet — check back soon.</p>
	</section>

	<script>
		const filterButtons = document.querySelectorAll<HTMLElement>('[data-lab-filter]');
		const cards = document.querySelectorAll<HTMLElement>('[data-lab-card]');
		const emptyState = document.getElementById('lab-empty');
		const validKeys = new Set(['experiments', 'tools', 'playground', 'ai', 'hardware']);

		function applyFilter(key: string) {
			let visibleCount = 0;
			cards.forEach((card) => {
				const match = key === 'all' || card.dataset.category === key;
				card.style.display = match ? '' : 'none';
				if (match) visibleCount++;
			});
			filterButtons.forEach((btn) => {
				const active = btn.dataset.labFilter === key;
				btn.classList.toggle('border-teal', active);
				btn.classList.toggle('bg-teal/10', active);
				btn.classList.toggle('border-border', !active);
				btn.classList.toggle('bg-white', !active);
			});
			if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
		}

		filterButtons.forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.preventDefault();
				const key = btn.dataset.labFilter ?? 'all';
				applyFilter(key);
				history.replaceState(null, '', key === 'all' ? '#lab-grid' : `#${key}`);
				document.getElementById('lab-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			});
		});

		const initialKey = location.hash.replace('#', '');
		applyFilter(validKeys.has(initialKey) ? initialKey : 'all');
	</script>

	{
		latestArticles.length > 0 && (
			<section class="mx-auto max-w-6xl px-6 py-10 md:px-12">
				<SectionHeader label="Latest Writing" linkText="View all articles" linkHref="/articles" />
				<div class="grid grid-cols-1 gap-2.5 lg:grid-cols-2">
					<ArticleTeaserCard entry={latestArticles[0]} variant="featured" />
					<div class="flex flex-col gap-2.5">
						{latestArticles.slice(1, 4).map((a) => (
							<ArticleTeaserCard entry={a} variant="compact" />
						))}
					</div>
				</div>
			</section>
		)
	}
</BaseLayout>
