---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import LabLayout from '../../layouts/LabLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const entries = await getCollection('lab');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

type Props = CollectionEntry<'lab'>;

const entry = Astro.props;
const { title, description, pubDate, labCategory, tags, status, demoUrl, sourceUrl, seo } = entry.data;
const { Content } = await render(entry);
---

<LabLayout title={seo.metaTitle ?? title} description={seo.metaDescription ?? description}>
	<Fragment slot="hero">
		<span class="lab-category">{labCategory}</span>
		<h1>{title}</h1>
		<p>{description}</p>
		<div class="meta">
			<FormattedDate date={pubDate} />
			<span>&middot;</span>
			<span>{status}</span>
		</div>
		<div class="tags">
			{tags.map((tag) => <span class="tag">{tag}</span>)}
		</div>
		<div class="facets">
			{demoUrl && <a href={demoUrl} target="_blank" rel="noopener noreferrer">Launch Demo &rarr;</a>}
			{sourceUrl && <a href={sourceUrl} target="_blank" rel="noopener noreferrer">View Source &rarr;</a>}
		</div>
	</Fragment>

	<div class="prose">
		<Content />
	</div>
</LabLayout>

<style>
	.lab-category {
		text-transform: uppercase;
		font-size: 0.8em;
		letter-spacing: 0.08em;
	}
	.meta {
		display: flex;
		gap: 0.5em;
		margin: 0.5em 0;
	}
	.tags {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin: 0.5em 0;
	}
	.tag {
		padding: 0.2em 0.7em;
		border-radius: 999px;
		border: 1px solid currentColor;
		font-size: 0.8em;
	}
	.facets {
		display: flex;
		gap: 1.5em;
		margin-top: 1em;
	}
	.facets a {
		color: inherit;
	}
</style>
