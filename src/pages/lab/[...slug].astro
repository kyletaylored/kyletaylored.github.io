---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import LabLayout from '../../layouts/LabLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const entries = await getCollection('lab');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

type Props = CollectionEntry<'lab'>;

const entry = Astro.props;
const { title, description, pubDate, labCategory, tags, status, demoUrl, sourceUrl, seo } = entry.data;
const { Content } = await render(entry);
---

<LabLayout title={seo.metaTitle ?? title} description={seo.metaDescription ?? description}>
	<Fragment slot="hero">
		<div class="mb-4 text-xs font-semibold tracking-widest text-teal uppercase">{labCategory}</div>
		<h1 class="mb-5 text-4xl leading-[1.05] font-bold tracking-tight text-bg md:text-5xl">{title}</h1>
		<p class="mb-6 max-w-[580px] text-lg leading-relaxed text-muted-light">{description}</p>
		<div class="mb-6 flex flex-wrap items-center gap-4">
			<div class="font-mono text-[11px] text-muted"><FormattedDate date={pubDate} /></div>
			<div class="h-8 w-px bg-border-dark"></div>
			<div class="font-mono text-[11px] text-muted uppercase">{status}</div>
		</div>
		<div class="mb-7 flex flex-wrap gap-1.5">
			{tags.map((tag) => <span class="rounded-full border border-border-dark px-2.5 py-0.5 text-[11px] text-muted">{tag}</span>)}
		</div>
		<div class="flex flex-wrap gap-3">
			{demoUrl && <Button href={demoUrl} variant="primary" target="_blank" rel="noopener noreferrer">Launch Demo &rarr;</Button>}
			{sourceUrl && <Button href={sourceUrl} variant="dark" target="_blank" rel="noopener noreferrer">View Source &rarr;</Button>}
		</div>
	</Fragment>

	<div class="prose">
		<Content />
	</div>
</LabLayout>
