---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Articles" description="Engineering journal — writeups, notes, and deep dives.">
	<PageHeader
		eyebrow="Engineering Journal"
		title="Articles"
		description="Writeups, notes, and deep dives on what I'm building."
	/>
	<div class="mx-auto max-w-4xl px-6 py-12 md:px-12">
		<div class="flex flex-col">
			{
				articles.map((a) => (
					<a
						href={`/articles/${a.id}/`}
						class="border-b border-border py-6 first:pt-0 last:border-b-0"
					>
						<div class="mb-2 text-xs font-semibold tracking-wide text-teal uppercase">{a.data.category}</div>
						<h2 class="mb-2 text-2xl font-bold text-ink">{a.data.title}</h2>
						<p class="mb-2 text-sm leading-relaxed text-muted">{a.data.description}</p>
						<div class="font-mono text-xs text-muted-light">
							<FormattedDate date={a.data.pubDate} />
						</div>
					</a>
				))
			}
		</div>
	</div>
</BaseLayout>
