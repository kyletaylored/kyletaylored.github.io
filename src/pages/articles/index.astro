---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ArticleTeaserCard from '../../components/ArticleTeaserCard.astro';
import LightSectionArt from '../../components/decor/LightSectionArt.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Articles" description="Engineering journal — writeups, notes, and deep dives.">
	<PageHeader
		eyebrow="Engineering Journal"
		title="Articles"
		description="Writeups, notes, and deep dives on what I'm building."
	/>
	<div class="relative mx-auto max-w-6xl overflow-hidden px-6 py-12 md:px-12">
		<LightSectionArt />
		<div class="relative grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{articles.map((a) => <ArticleTeaserCard entry={a} variant="vertical" />)}
		</div>
	</div>
</BaseLayout>
