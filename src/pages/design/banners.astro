---
// Private, unlinked utility page — NOT real site content. Renders the
// static (non-per-page) assets from
// ui_kits/banners/Social Banners.dc.html at true pixel size using real
// site content. Each banner ships a "Download PNG" link to a satori-
// rendered, 2x-resolution export (src/pages/design/banners/[variant].png.ts)
// so these no longer need to be screenshotted out of the browser — the
// on-page preview and the download share the same decorative-shape specs
// (src/lib/bannerSpecs.ts) so they stay visually in sync. Excluded from the
// sitemap (astro.config.mjs's sitemap filter) and from Pagefind
// (data-pagefind-ignore below) since it's not something visitors should
// ever land on or search for. Not linked from any nav — reach it by typing
// the URL directly.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';
import { shapesToHtml } from '../../lib/bannerArt';
import { BANNER_SPECS } from '../../lib/bannerSpecs';

const [latestArticle] = (await getCollection('articles', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const readingTime = latestArticle
	? Math.max(1, Math.round((latestArticle.body ?? '').trim().split(/\s+/).filter(Boolean).length / 200))
	: 1;

const linkedinLeft = BANNER_SPECS['linkedin-left'];
const linkedinRight = BANNER_SPECS['linkedin-right'];
const github = BANNER_SPECS.github;
const email = BANNER_SPECS.email;
const squareHome = BANNER_SPECS['square-home'];
const squareArticle = BANNER_SPECS['square-article'];
---

<BaseLayout title="Banner Export" description="Private banner export utility." noindex={true}>
	<div data-pagefind-ignore class="px-6 py-12 md:px-12">
		<div class="mx-auto mb-12 max-w-3xl">
			<h1 class="mb-2 text-2xl font-bold text-ink">Banner Export</h1>
			<p class="text-sm text-muted">
				Real-pixel-size banners (LinkedIn profile, GitHub social preview, email header, square social crops)
				for manual upload to LinkedIn/GitHub/an email tool. Each has a "Download PNG" link for a
				high-resolution export — no screenshotting required. Not linked anywhere; not in the sitemap.
			</p>
		</div>

		<div class="mx-auto flex max-w-[1600px] flex-col gap-16">
			<div>
				<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
					<span>{linkedinLeft.dims} — {linkedinLeft.label}</span>
					<a href="/design/banners/linkedin-left.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
				</div>
				<p class="mb-3 text-xs text-muted">Use this variant if LinkedIn's circular profile photo (bottom-left of the cover) doesn't overlap your text.</p>
				<div class="relative flex h-[396px] w-[1584px] items-center overflow-hidden bg-ink px-16">
					<Fragment set:html={shapesToHtml(linkedinLeft.shapes)} />
					<div class="relative">
						<div class="mb-3.5 flex items-center gap-2.5">
							<div class="flex h-7 w-7 items-center justify-center rounded-sm bg-teal text-sm font-bold text-ink">K</div>
							<span class="text-xs font-semibold tracking-widest text-muted uppercase">{site.brandLabel}</span>
						</div>
						<div class="mb-2.5 text-5xl font-bold tracking-tight text-bg">
							{site.siteSubtitle}<span class="text-pink">.</span>
						</div>
						<div class="font-mono text-base text-muted-light">kyletaylored.com</div>
					</div>
				</div>
			</div>

			<div>
				<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
					<span>{linkedinRight.dims} — {linkedinRight.label}</span>
					<a href="/design/banners/linkedin-right.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
				</div>
				<p class="mb-3 text-xs text-muted">Use this variant instead — content sits on the right, clear of the profile photo overlay.</p>
				<div class="relative flex h-[396px] w-[1584px] items-center justify-end overflow-hidden bg-ink px-16">
					<Fragment set:html={shapesToHtml(linkedinRight.shapes)} />
					<div class="relative text-right">
						<div class="mb-3.5 flex items-center justify-end gap-2.5">
							<span class="text-xs font-semibold tracking-widest text-muted uppercase">{site.brandLabel}</span>
							<div class="flex h-7 w-7 items-center justify-center rounded-sm bg-teal text-sm font-bold text-ink">K</div>
						</div>
						<div class="mb-2.5 text-5xl font-bold tracking-tight text-bg">
							{site.siteSubtitle}<span class="text-pink">.</span>
						</div>
						<div class="font-mono text-base text-muted-light">kyletaylored.com</div>
					</div>
				</div>
			</div>

			<div>
				<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
					<span>{github.dims} — {github.label}</span>
					<a href="/design/banners/github.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
				</div>
				<div class="relative flex h-[640px] w-[1280px] overflow-hidden bg-ink">
					<div class="flex w-[520px] flex-col border-r border-border-dark bg-[#0D0D0D]">
						<div class="flex items-center gap-1.5 border-b border-border-dark bg-[#1A1A1A] px-7 py-5">
							<span class="h-3 w-3 rounded-full bg-red"></span>
							<span class="h-3 w-3 rounded-full bg-yellow"></span>
							<span class="h-3 w-3 rounded-full bg-teal"></span>
							<span class="ml-3 font-mono text-sm text-muted">kyletaylored/kyletaylored.github.io</span>
						</div>
						<div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-3 p-7 font-mono text-sm leading-loose">
							<span class="text-teal">$</span><span class="text-bg">git clone kyletaylored.github.io</span>
							<span class="text-teal">→</span><span class="text-muted">Cloning...</span>
							<span class="text-teal">$</span><span class="text-bg">npm run dev</span>
							<span class="text-teal">→</span><span class="text-teal">Ready on :4321</span>
						</div>
					</div>
					<div class="relative flex flex-1 flex-col justify-center px-12">
						<Fragment set:html={shapesToHtml(github.shapes)} />
						<div class="relative">
							<div class="mb-4 flex items-center gap-2">
								<div class="flex h-5 w-5 items-center justify-center rounded-sm bg-teal text-xs font-bold text-ink">K</div>
								<span class="font-mono text-xs tracking-wide text-muted uppercase">kyletaylored.com</span>
							</div>
							<div class="mb-3 text-3xl font-bold text-bg">
								{site.brandLabel}<span class="text-pink">.</span>
							</div>
							<p class="mb-4 max-w-[380px] text-sm leading-relaxed text-muted-light">{site.siteDescription}</p>
							<div class="flex flex-wrap gap-1.5">
								{['TypeScript', 'Astro', 'AI', 'Open Source'].map((tag) => (
									<span class="rounded-full border border-border-dark px-2.5 py-0.5 text-xs text-muted-light">{tag}</span>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>

			<div>
				<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
					<span>{email.dims} — {email.label}</span>
					<a href="/design/banners/email.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
				</div>
				<div class="relative flex h-[200px] w-[600px] items-center overflow-hidden bg-ink px-9">
					<Fragment set:html={shapesToHtml(email.shapes)} />
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<div class="flex h-5 w-5 items-center justify-center rounded-sm bg-teal text-xs font-bold text-ink">K</div>
							<span class="text-xs font-semibold tracking-widest text-bg uppercase">{site.brandLabel}</span>
						</div>
						<div class="text-2xl font-bold text-bg">Lab Notes<span class="text-pink">.</span></div>
						<div class="mt-1.5 font-mono text-xs text-muted">Issue # — replace per send</div>
					</div>
				</div>
			</div>

			<div class="flex flex-wrap gap-10">
				<div>
					<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
						<span>{squareHome.dims} — {squareHome.label}</span>
						<a href="/design/banners/square-home.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
					</div>
					<div class="relative flex h-[1080px] w-[1080px] flex-col justify-end overflow-hidden bg-ink p-14">
						<Fragment set:html={shapesToHtml(squareHome.shapes)} />
						<div class="relative">
							<div class="mb-4 flex items-center gap-2.5">
								<div class="flex h-9 w-9 items-center justify-center rounded-md bg-teal text-lg font-bold text-ink">K</div>
								<span class="text-lg font-semibold tracking-widest text-bg uppercase">{site.brandLabel}</span>
							</div>
							<div class="text-6xl leading-[1.05] font-bold text-bg">
								Hi, I'm <span class="text-teal">Kyle</span><span class="text-pink">.</span>
							</div>
						</div>
					</div>
				</div>

				{
					latestArticle && (
						<div>
							<div class="mb-3 flex items-center justify-between font-mono text-xs text-muted">
								<span>{squareArticle.dims} — {squareArticle.label}</span>
								<a href="/design/banners/square-article.png" download class="font-sans text-xs font-semibold text-teal hover:underline">↓ Download PNG</a>
							</div>
							<div class="relative flex h-[1080px] w-[1080px] flex-col justify-end overflow-hidden bg-ink p-14">
								<Fragment set:html={shapesToHtml(squareArticle.shapes)} />
								<div class="relative">
									<div class="mb-5 inline-block rounded-full bg-pink px-5 py-2 text-lg font-semibold uppercase text-white">
										{latestArticle.data.category}
									</div>
									<div class="mb-6 text-6xl leading-[1.05] font-bold text-bg">{latestArticle.data.title}</div>
									<div class="font-mono text-lg text-muted">
										{readingTime} min read · {latestArticle.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
									</div>
								</div>
							</div>
						</div>
					)
				}
			</div>
		</div>
	</div>
</BaseLayout>
