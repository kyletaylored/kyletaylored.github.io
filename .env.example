# Optional — populated from repo secrets during CI builds (see
# .github/workflows/deploy.yml), not required for local `npm run dev`/`build`.
# Everything in src/components/Analytics.astro and astro.config.mjs's
# Datadog Vite plugin no-ops when these are unset.

GTM_ID=

# RUM (src/components/Analytics.astro — @datadog/browser-rum)
DATADOG_RUM_APPLICATION_ID=
DATADOG_RUM_CLIENT_TOKEN=
DATADOG_RUM_SITE=datadoghq.com
DATADOG_RUM_SERVICE=kyletaylored-website
DATADOG_RUM_ENV=production
# Must match DATADOG_API_KEY's sourcemap releaseVersion below, or Error
# Tracking can't symbolicate stack traces against the uploaded source.
# CI sets this to the deploying commit SHA automatically.
DATADOG_RUM_VERSION=

# Sourcemap upload for Error Tracking (astro.config.mjs — @datadog/vite-plugin)
DATADOG_API_KEY=
DATADOG_APP_KEY=
